# Supabase — copy to .env.local and fill with your project values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (NEVER expose to the browser). Used for privileged server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Claude API — powers PDF analysis on /kosztorys (AI-assisted cost estimate extraction)
ANTHROPIC_API_KEY=
